%% sga1-macros.sty
%% Slim macro package distilled from the original sga1-smf.sty for the
%% normalized SGA1 tree. Contains only content-bearing definitions (math
%% operators, sheaf/blackboard/fraktur notation, French typography, theorem
%% environments). Editorial apparatus, hyperref/SMF-class patches, the title
%% page, and the active-paren / `l`->ell catcode tricks have been removed.
%% The dual-edition `orig` conditionals were already resolved by the pipeline;
%% the few orig-conditional macros (\fets, \nieme, \Gl, ...) are defined here in
%% their *corrected* form (\setboolean{orig}{false}).

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{sga1-macros}[2026/06/28 SGA1 normalized macros]

%% --- Counters / sectioning (exposes use Roman numerals named "Expose") ------
\renewcommand{\thechapter}{\Roman{chapter}}
\renewcommand{\thesection}{\arabic{section}}
\renewcommand{\thesubsection}{\thesection.\arabic{subsection}}
\renewcommand{\thesubsubsection}{\thesubsection.\arabic{subsubsection}}
\setcounter{secnumdepth}{4}
\renewcommand{\theequation}{\arabic{equation}}
\numberwithin{equation}{section}
\AtBeginDocument{\renewcommand{\chaptername}{Expos\'e}}

