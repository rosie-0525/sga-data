\newtheorem*{scholiestar}{Scholie}

\def\qedsymbol{\textup{C.Q.F.D.}}
\let\CQFD\qed
\let\cqfd\qed

%% Unnumbered enonce*-style environment (smfthm) + the Raynaud "remarqueMR".
\newenvironment{enonce*}[2][plain]
  {\par\medskip\noindent\textbf{#2}\itshape\par\nobreak\smallskip\nobreak}
  {\par\medskip}
\def\lcrochetbf{\textbf{[}}
\def\rcrochetbf{\textbf{]}}
\newenvironment{remarqueMR}
  {\begin{enonce*}[remark]{\lcrochetbf Remarque}}
  {\unskip\rcrochetbf\end{enonce*}}
\newenvironment{enumerateb}{\begin{enumerate}}{\end{enumerate}}

