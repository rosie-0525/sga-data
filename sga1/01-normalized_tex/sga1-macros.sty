%% --- Per-exposé bibliography (SMF two-argument form) ------------------------
%% SGA1 has a \thebibliography per exposé, taking TWO args:
%%   \begin{thebibliography}{<widest label>}{<section label, e.g. VI.13>}
%% (book.cls's default takes one). #2 becomes a \label so \ref/\cite resolve.
\def\bibliofont{\def\baselinestretch{1}\normalfont}
\renewenvironment{thebibliography}[2]{%
  \section{\bibname}\label{#2}%
  \normalfont\labelsep .5em\relax
  \renewcommand\theenumiv{\arabic{enumiv}}\let\p@enumiv\@empty
  \list{\@biblabel{\theenumiv}}{\settowidth\labelwidth{\@biblabel{#1}}%
    \itemindent 0pt
    \leftmargin\labelwidth \advance\leftmargin\labelsep
    \usecounter{enumiv}}%
    \itemsep 0.1\baselineskip plus0.1\baselineskip minus0.1\baselineskip
    \bibliofont
  \sloppy \clubpenalty\@M \widowpenalty\clubpenalty
  \sfcode`\.=\@m
}{%
  \def\@noitemerr{\@latex@warning{Empty `thebibliography' environment}}%
  \endlist
}

