%% Unnumbered theorem-like environment used in chapters X, XI, XII, XIV.
%% Signature: \begin{enonce*}[opt-style]{title}[opt-notes].
%% We accept the optional [style] and {title}; trailing [notes] (if any)
%% renders inline at the start of the body, which is harmless.
\providecommand{\@enoncestyle}{plain}
\newenvironment{enonce*}[2][plain]
  {\par\medskip\noindent\textbf{#2}\itshape\par\nobreak\smallskip\nobreak}
  {\par\medskip}

