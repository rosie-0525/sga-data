%% French typography & citation shortcuts.
%% Use \space (and \, for the inter-word gap in loc. cit.) instead of \xspace
%% and \kern, which the HTML converter either chokes on (\xspace) or leaks
%% dimensions into the output for (\kern.3em -> ".3em").
\def\cf{cf.\space}
\def\Cf{Cf.\space}
\def\ie{i.e.\space}
\def\iev{i.e., }
\def\loccit{loc.\,cit.\space}
\def\EGA{\textup{EGA}\space}
\def\SGA{\textup{SGA}\space}
\let\oldS\S
\def\S{\oldS\space}
\def\resp{resp.\space}
\def\Exp{Exp.\space}
%% French guillemets. Emit literal Unicode guillemets rather than relying on
%% \og / \guillemotleft, which the HTML converter may drop or mistranslate,
%% leaving orphan » in the output. pdflatex maps the literal glyphs back
%% through inputenc/T1, and the HTML converter passes them straight through.
\def\og{«\,}
\def\fg{\,»}
\def\numero{n\textsuperscript{o}\space}

