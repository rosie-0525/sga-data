\def\Ssi{\mathchoice{\Longleftrightarrow}{\Leftrightarrow}{\Leftrightarrow}{\Leftrightarrow}}
\newcommand{\isomto}{\overset{\sim}{\longrightarrow}}
\newcommand{\isomfrom}{\overset{\sim}{\longleftarrow}}
\newcommand{\SSI}{\unskip~$\Ssi$~\ignorespaces}
\newcommand{\ALORS}{\unskip~$\To$~\ignorespaces}

