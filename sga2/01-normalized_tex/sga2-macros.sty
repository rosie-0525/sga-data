%% sga2-macros.sty
%% Slim macro package distilled from the original sga2-smf.sty for the
%% normalized SGA2 tree. Contains only content-bearing
%% definitions (math operators, sheaf shorthand, French typography,
%% theorem environments). Editorial apparatus, hyperref patches and
%% active-paren catcodes have been removed.

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{sga2-macros}[2026/05/24 SGA2 normalized macros]

%% \sisi was already resolved by the pipeline; define as identity in case any
%% straggler survived.
\providecommand{\sisi}[2]{#1}

%% Chapter numbering: expos\'es use Roman numerals named "Expos\'e".
\renewcommand{\thechapter}{\Roman{chapter}}
\AtBeginDocument{\renewcommand{\chaptername}{Expos\'e}}
\renewcommand{\thesection}{\arabic{section}}
\renewcommand{\thesubsection}{\thesection.\arabic{subsection}}
\renewcommand{\thesubsubsection}{\thesubsection.\arabic{subsubsection}}
\renewcommand{\theequation}{\arabic{equation}}
\setcounter{secnumdepth}{4}

\newcounter{yequation}[chapter]
\newcommand{\steco}{\setcounter{equation}{\value{yequation}}\refstepcounter{yequation}}
\newcounter{toto}
\newcounter{footnoteAG}
\newcounter{footnoteNDE}

%% Theorem environments
\theoremstyle{plain}
\newtheorem{theoreme}[subsection]{Th\'eor\`eme}
\newtheorem{proposition}[subsection]{Proposition}
\newtheorem{lemme}[subsection]{Lemme}
\newtheorem{corollaire}[subsection]{Corollaire}
\newtheorem{corollaires}[subsection]{Corollaires}
\newtheorem{conjecture}[subsection]{Conjecture}
\newtheorem{probleme}[subsection]{Probl\`eme}
\newtheorem{theoremedefinition}[subsection]{Th\'eor\`eme et d\'efinition}
\newtheorem{subproposition}[subsubsection]{Proposition}
\newtheorem{propositionblah}[subsubsection]{Proposition}
\newtheorem{criteredenormalitedeserre}[subsection]{Crit\`ere de normalit\'e de Serre}
\newtheorem{sublemme}[subsubsection]{Lemme}
\newtheorem{subsublemme}[paragraph]{Lemme}
\newtheorem{supproposition}[section]{Proposition}
\newtheorem{suplemme}[section]{Lemme}
\newtheorem{suptheoreme}[section]{Th\'eor\`eme}
\newtheorem{supcorollaire}[section]{Corollaire}
\newtheorem{aconjecture}{Conjecture}[section]
\renewcommand{\theaconjecture}{\Alph{aconjecture}}

\theoremstyle{remark}
\newtheorem{definition}[subsection]{D\'efinition}
\newtheorem{remarque}[subsection]{Remarque}
\newtheorem{remarques}[subsection]{Remarques}
\newtheorem{exemple}[subsection]{Exemple}
\newtheorem{subremarque}[subsubsection]{Remarque}
\newtheorem{supdefinition}{Definition}[chapter]
\renewcommand{\thesupdefinition}{\arabic{supdefinition}}
\newtheorem*{remarquestar}{Remarque}

\def\qedsymbol{\textup{C.Q.F.D.}}
\let\CQFD\qed
\let\cqfd\qed

%% Enumerate variants
\newenvironment{enumeratei}
  {\bgroup\def\theenumi{\roman{enumi}}\def\theenumii{\arabic{enumii}}\begin{enumerate}}
  {\end{enumerate}\egroup}
\newenvironment{enumeratea}
  {\bgroup\def\theenumi{\alph{enumi}}\def\labelenumi{\textup{\theenumi)}}\begin{enumerate}}
  {\end{enumerate}\egroup}

